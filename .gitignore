# WordPress Plugin .gitignore
# This file tells Git which files and folders to ignore

# WordPress core files (if plugin is in wp-content/plugins/)
/wp-admin/
/wp-content/
/wp-includes/
/wp-*.php
/index.php
/xmlrpc.php
/readme.html
/license.txt

# Plugin-specific ignores
/vendor/
/node_modules/
/debug-google.txt
*.log
*.tmp
*.bak

# PHP
*.php~
*.php.bak

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Build and dist files
/build/
/dist/
/assets/css/*.min.css
/assets/js/*.min.js

# Environment and config files
.env
.env.local
.env.*.local
config.local.php

# Cache files
/cache/
/tmp/

# Database dumps
*.sql
*.sql.gz

# Composer
/vendor/
composer.lock

# Node.js
/node_modules/
/npm-debug.log*
/yarn-debug.log*
/yarn-error.log*

# Testing
/tests/bin/
/tests/coverage/
/phpunit.xml

# Archives
*.zip
*.tar.gz
*.rar

# WordPress uploads (if any test uploads exist)
/uploads/

# Debug and temporary files
debug-*.txt
temp-*.txt